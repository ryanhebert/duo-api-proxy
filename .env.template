# =================================================================
# Duo Admin API OAuth 2.1 Proxy Configuration Template
# =================================================================
# NOTE: You can run 'python scripts/setup.py' to generate this file 
# automatically through an interactive prompt.
# =================================================================

# --- Duo Admin API (Backend Credentials) ---
# Found in: Duo Admin Panel -> Applications -> Admin API
DUO_HOST=api-xxxxxxxx.duosecurity.com
DUO_IKEY=DIXXXXXXXXXXXXXXXXXX
DUO_SKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Duo SSO / OIDC (Frontend Authentication) ---
# Found in: Duo Admin Panel -> Applications -> OAuth 2.1 / OIDC
DUO_SSO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXX
DUO_SSO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DUO_SSO_WELL_KNOWN_URL=https://api-xxxxxxxx.duosecurity.com/oidc/v1/.well-known/openid-configuration

# --- Proxy Security & Settings ---
# Gunicorn worker count (Recommended: 2 or 4 for containerized environments)
GUNICORN_WORKERS=
# A long random string used to sign browser session cookies
PROXY_SESSION_SECRET=generate-a-secure-random-string-here
PROXY_PORT=8000

# Set to false to hide the Swagger UI and OpenAPI spec in production
PROXY_ENABLE_DOCS=true

# SSL Settings
PROXY_USE_HTTPS=false
PROXY_CERT_PATH=certs/proxy.crt
PROXY_KEY_PATH=certs/proxy.key

# Optional: Path to the OpenAPI YAML specification
OPENAPI_SPEC_PATH=../duoMcp/duo-admin-api.yaml

# Optional: How many seconds to cache Duo user status (Default: 30)
# This controls how often the proxy "phones home" to Duo to verify active status.
REVOCATION_CHECK_CACHE_SECONDS=30

# --- Dynamic Client Registration (DCR) ---
# Set to true to allow clients to register themselves via POST /register
PROXY_ENABLE_DCR=false
# Optional: Require this token in the 'Authorization: Bearer <token>' header to allow registration
DCR_INITIAL_ACCESS_TOKEN=

# --- Distributed Caching (Optional) ---
# Required if running multiple instances. Leave blank for in-memory.
# Example: redis://localhost:6379/0
REDIS_URL=
